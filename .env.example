# =============================================================================
# Zuper Agent Framework — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# These are INFRA secrets — business config goes in clients/*/config.yaml
# =============================================================================

# Client to load (matches clients/<CLIENT_ID>/config.yaml)
CLIENT_ID=example

# LLM Gateway (Bifrost)
BIFROST_URL=http://bifrost:8080/v1
BIFROST_API_KEY=dummy

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Z-API
ZAPI_INSTANCE=your-instance-id
ZAPI_TOKEN=your-instance-token
ZAPI_CLIENT_TOKEN=your-client-token
ZAPI_BASE_URL=https://api.z-api.io/instances

# N8N (optional, for external integrations)
N8N_BASE_URL=http://n8n:5678

# Server
PORT=8000
