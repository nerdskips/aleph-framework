# =============================================================================
# Zuper Agent Framework — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# git-ignored — NEVER commit this file.
#
# Rule: INFRA secrets go here, BUSINESS config goes in clients/*/config.yaml
# =============================================================================

# --- Client ---
# Which agent to load (matches clients/<CLIENT_ID>/config.yaml)
CLIENT_ID=example

# --- LLM Gateway (Bifrost) ---
# Bifrost routes to multiple LLM providers (OpenAI, Gemini, DeepSeek, etc)
# If you don't have Bifrost, see docs for direct API key setup
BIFROST_URL=http://localhost:8080/v1
BIFROST_API_KEY=dummy

# Disable SDK trace export (avoids OPENAI_API_KEY warning in logs)
OPENAI_AGENTS_DISABLE_TRACING=1

# --- Redis ---
# Required: used for session buffer, anti-spam, locks, escalation state
# Format: redis://:PASSWORD@HOST:PORT/DB
REDIS_URL=redis://:password@localhost:6379/0

# --- Z-API (WhatsApp) ---
# Get these from your Z-API dashboard (https://developer.z-api.io)
# Each agent needs its own Z-API instance
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- Database (Postgres) ---
# Required ONLY when habits.enabled=true in config.yaml
# Works with any Postgres that has pgvector extension
#
# Self-hosted:
#   DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
#
# Supabase (pooler for queries):
#   DATABASE_URL=postgresql://postgres.xxx:pass@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
#   DATABASE_MIGRATION_URL=postgresql://postgres.xxx:pass@db.xxx.supabase.co:5432/postgres
#
DATABASE_URL=
# DATABASE_MIGRATION_URL=

# --- N8N (optional) ---
# Only needed if your agent's webhook tools point to N8N
# N8N_BASE_URL=http://n8n:5678
