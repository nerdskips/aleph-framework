# =============================================================================
# Aleph — {{AGENT_NAME}}
# =============================================================================
# This file contains secrets and credentials. NEVER commit to git.
# Copy to .env and fill in your values.
# =============================================================================

CLIENT_ID={{AGENT_NAME}}

# --- LLM Provider (uncomment ONE) ----------------------------------------
# The framework auto-detects the provider based on which key is set.

# OpenAI
# OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Google Gemini
# GEMINI_API_KEY=AIzaSy-YOUR_KEY_HERE

# DeepSeek
# DEEPSEEK_API_KEY=sk-YOUR_KEY_HERE

# OpenRouter
# OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE

# Bifrost gateway (self-hosted)
# BIFROST_URL=http://localhost:8080/v1
# BIFROST_API_KEY=dummy

# Custom endpoint
# LLM_BASE_URL=https://your-endpoint/v1
# LLM_API_KEY=your-key

# --- Redis ----------------------------------------------------------------
REDIS_URL=redis://:YOUR_PASSWORD@YOUR_HOST:6379/0

# --- Z-API (WhatsApp) ----------------------------------------------------
ZAPI_INSTANCE=YOUR_INSTANCE_ID
ZAPI_TOKEN=YOUR_TOKEN
ZAPI_CLIENT_TOKEN=YOUR_CLIENT_TOKEN

# --- Database (only if habits.enabled=true) -------------------------------
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Framework settings ---------------------------------------------------
OPENAI_AGENTS_DISABLE_TRACING=1
